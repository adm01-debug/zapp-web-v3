# NUNCA commitar o arquivo .env com valores reais!

# ==============================================================================
# SUPABASE (OBRIGATÓRIO)
# ==============================================================================
VITE_SUPABASE_URL=https://allrjhkpuscmgbsnmjlv.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# External CRM Database (Contact 360° enrichment)
VITE_EXTERNAL_SUPABASE_URL=https://pgxfvjmuubtbowutlide.supabase.co
VITE_EXTERNAL_SUPABASE_ANON_KEY=your-external-anon-key

# ==============================================================================
# EVOLUTION API - WHATSAPP (OBRIGATÓRIO para Edge Functions)
# ==============================================================================
EVOLUTION_API_URL=https://evolution.atomicabr.com.br
EVOLUTION_API_KEY=sua-evolution-api-key

# ==============================================================================
# SENTRY - OBSERVABILIDADE (RECOMENDADO)
# ==============================================================================
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
VITE_SENTRY_ENVIRONMENT=development

# ==============================================================================
# GMAIL INTEGRATION - OAUTH2 (OPCIONAL)
# ==============================================================================
GMAIL_CLIENT_ID=xxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxx
GMAIL_REDIRECT_URI=https://allrjhkpuscmgbsnmjlv.supabase.co/functions/v1/gmail-oauth

# ==============================================================================
# AI PROVIDERS - CHATBOTS (OPCIONAL)
# ==============================================================================
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GROQ_API_KEY=gsk_xxx

# ==============================================================================
# APP CONFIG
# ==============================================================================
VITE_APP_NAME=ZAPP-WEB
VITE_APP_ENV=development

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
VITE_ENABLE_GAMIFICATION=true
VITE_ENABLE_GMAIL_INTEGRATION=false

