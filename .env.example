# ==============================================================================
# ZAPP-WEB - CONFIGURAÇÃO DE AMBIENTE
# ==============================================================================
# Copie este arquivo para .env.local e preencha com os valores reais
# NUNCA commitar o arquivo .env com valores reais!

# ==============================================================================
# SUPABASE (OBRIGATÓRIO)
# ==============================================================================
VITE_SUPABASE_URL=https://supabase.atomicabr.com.br
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# External CRM Database (Contact 360° enrichment)
VITE_EXTERNAL_SUPABASE_URL=https://pgxfvjmuubtbowutlide.supabase.co
VITE_EXTERNAL_SUPABASE_ANON_KEY=your-external-anon-key

# ==============================================================================
# EVOLUTION API - WHATSAPP (OBRIGATÓRIO para Edge Functions)
# ==============================================================================
EVOLUTION_API_URL=https://evolution.atomicabr.com.br
EVOLUTION_API_KEY=sua-evolution-api-key

# Webhook signature secret(s). Single value for legacy mode, OR a comma-separated
# list for zero-downtime rotation. When rotating: deploy with [new,old] →
# update Evolution to use `new` → drop `old`. Slot 0 (first) is always the
# primary used for outbound signing.
#   EVOLUTION_WEBHOOK_SECRET=single-secret           # legacy single-secret
#   EVOLUTION_WEBHOOK_SECRETS=new-secret,old-secret  # rotation
EVOLUTION_WEBHOOK_SECRET=
# EVOLUTION_WEBHOOK_SECRETS=

# Strict signature validation. When `true`, unsigned webhooks are rejected.
# Default true on production, can be `false` during initial onboarding.
EVOLUTION_WEBHOOK_STRICT=true

# Per-instance send rate limit (sends/min). Capped at the edge function before
# hitting Evolution; protects WhatsApp accounts from runaway loops. The global
# IP-based limit (120/min) remains the outer ceiling. 0 disables this layer.
EVOLUTION_SEND_RATE_PER_INSTANCE=60

# ==============================================================================
# SENTRY - OBSERVABILIDADE (RECOMENDADO)
# ==============================================================================
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
VITE_SENTRY_ENVIRONMENT=development

# ==============================================================================
# GMAIL INTEGRATION - OAUTH2 (OPCIONAL)
# ==============================================================================
GMAIL_CLIENT_ID=xxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxx
GMAIL_REDIRECT_URI=https://YOUR-SELF-HOSTED-SUPABASE-URL/functions/v1/gmail-oauth

# ==============================================================================
# AI PROVIDERS - CHATBOTS (OPCIONAL)
# ==============================================================================
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GROQ_API_KEY=gsk_xxx

# ==============================================================================
# APP CONFIG
# ==============================================================================
VITE_APP_NAME=ZAPP-WEB
VITE_APP_ENV=development

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
VITE_ENABLE_GAMIFICATION=true
VITE_ENABLE_GMAIL_INTEGRATION=false

# ==============================================================================
# BITRIX24 (OPCIONAL - se integrado)
# ==============================================================================
# VITE_BITRIX_WEBHOOK_URL=https://promobrindes.bitrix24.com.br/rest/1/xxx/

# ==============================================================================
# STORAGE R2 (OPCIONAL)
# ==============================================================================
# R2_ACCOUNT_ID=xxx
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx
# R2_BUCKET_NAME=zapp-media

# ==============================================================================
# EVOLUTION API (Frontend - optional, used by WhatsApp adapter)
# ==============================================================================
VITE_EVOLUTION_API_URL=https://evolution.atomicabr.com.br
VITE_EVOLUTION_API_KEY=your-evolution-api-key

# ==============================================================================
# SUPABASE EXTRAS
# ==============================================================================
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=same-as-anon-key

# ==============================================================================
# LOGGING
# ==============================================================================
VITE_LOG_LEVEL=info
