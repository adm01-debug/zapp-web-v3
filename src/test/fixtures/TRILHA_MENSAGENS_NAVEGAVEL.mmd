    UM["useMessages"]
    UMS["useMessageStatus"]
    UMSS["useMessageSendStatus"]
  end

  subgraph RT["5. Realtime e Batching"]
    BATCH["useMessageUpdateBatcher"]
    URM["useRealtimeMessages"]
