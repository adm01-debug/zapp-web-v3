# ============================================
# ZAPP-WEB .gitignore - Segurança Primeiro!
# ============================================

# ====================
# SECRETS E AMBIENTE (CRÍTICO!)
# ====================
.env
.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
*.pem
*.key
*.crt
*.p12
secrets/
.secrets
credentials.json
service-account.json
firebase-adminsdk*.json

# Credenciais em texto plano (PT-BR e EN)
*credencia*.txt
*credential*.txt
*cred*.txt
*token*.txt
*apikey*.txt
*api_key*.txt
*senha*.txt
*password*.txt
*secret*.txt
*chave*.txt

# ====================
# LOGS
# ====================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# ====================
# DEPENDÊNCIAS
# ====================
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
# Project uses bun (bun.lock is the source of truth) — ignore other lockfiles
# generated by accidental npm/yarn/pnpm installs.
package-lock.json
yarn.lock
pnpm-lock.yaml
# Deno lockfile generated by local `deno test` runs against
# supabase/functions/. Not tracked: the edge functions resolve URL imports
# fresh in CI/Supabase — pinning them via deno.lock locally would only mask
# transient esm.sh issues, never reproduce CI behaviour.
deno.lock

# ====================
# BUILD E PRODUÇÃO
# ====================
dist/
dist-ssr/
build/
.next/
out/
*.local

# ====================
# CACHE
# ====================
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
.vite/
*.tsbuildinfo

# ====================
# TESTES
# ====================
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# ====================
# EDITOR E IDE
# ====================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.sublime-workspace
*.sublime-project
.project
.classpath
.settings/

# ====================
# SISTEMA OPERACIONAL
# ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# ====================
# SUPABASE LOCAL
# ====================
supabase/.branches/
supabase/.temp/
.supabase/

# ====================
# ARQUIVOS GRANDES
# ====================
*.zip
*.tar.gz
*.rar
*.7z

# ====================
# BACKUPS
# ====================
*.bak
*.backup
*_backup*
*_old*
*.orig

# ====================
# OUTROS
# ====================
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.eslintcache
.stylelintcache
*.tgz
.yarn-integrity
