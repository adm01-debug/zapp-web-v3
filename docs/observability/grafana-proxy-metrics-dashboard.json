{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Observabilidade do endpoint external-db-proxy via /proxy-metrics (Prometheus). Painéis: erro %, RPS, latência p50/p95/p99, status HTTP e códigos de erro upstream (PGRST002, 57014).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["proxy", "supabase", "external-db-proxy", "zapp-web"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "label": "Data source",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "target",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(proxy_requests_total, target)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "label": "Target",
        "sort": 1
      },
      {
        "name": "op",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(proxy_requests_total{target=~\"$target\"}, op)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "label": "Operation",
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "External DB Proxy — Observability",
  "uid": "proxy-metrics-overview",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Saúde geral",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Taxa de erro (%)",
      "description": "errors / total no janelamento atual do range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(increase(proxy_requests_error_total{target=~\"$target\",op=~\"$op\"}[$__range])) / clamp_min(sum(increase(proxy_requests_total{target=~\"$target\",op=~\"$op\"}[$__range])), 1)",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / s",
      "description": "Throughput médio no range selecionado.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(proxy_requests_total{target=~\"$target\",op=~\"$op\"}[5m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Hard timeouts (14s wrapper)",
      "description": "Timeouts de borda do proxy (proxy_requests_timeout_fired_total).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(proxy_requests_timeout_fired_total{target=~\"$target\",op=~\"$op\"}[$__range]))",
          "legendFormat": "timeouts"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Postgres timeouts (57014)",
      "description": "Statements abortados pelo Postgres no range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(proxy_requests_pg_timeout_total{target=~\"$target\",op=~\"$op\"}[$__range]))",
          "legendFormat": "pg timeouts"
        }
      ]
    },

    {
      "type": "row",
      "id": 200,
      "title": "Erro & throughput ao longo do tempo",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Taxa de erro % (5m rolling)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (target) (rate(proxy_requests_error_total{target=~\"$target\",op=~\"$op\"}[5m])) / clamp_min(sum by (target) (rate(proxy_requests_total{target=~\"$target\",op=~\"$op\"}[5m])), 0.001)",
          "legendFormat": "{{target}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Throughput por operação (rps)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal", "group": "A" } }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (op) (rate(proxy_requests_total{target=~\"$target\",op=~\"$op\"}[5m]))",
          "legendFormat": "{{op}}"
        }
      ]
    },

    {
      "type": "row",
      "id": 300,
      "title": "Latência",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Latência p50 / p95 / p99 (ms) — agregada",
      "description": "Quantis emitidos pelo /proxy-metrics (computados em janela). Use max para enxergar o pior alvo a cada scrape.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "expr": "max(proxy_request_duration_ms{quantile=\"0.5\",target=~\"$target\",op=~\"$op\"})",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "max(proxy_request_duration_ms{quantile=\"0.95\",target=~\"$target\",op=~\"$op\"})",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "max(proxy_request_duration_ms{quantile=\"0.99\",target=~\"$target\",op=~\"$op\"})",
          "legendFormat": "p99"
        },
        {
          "refId": "D",
          "expr": "max(proxy_request_duration_ms{quantile=\"avg\",target=~\"$target\",op=~\"$op\"})",
          "legendFormat": "avg"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "p95 por operação",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 16 },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "orange", "value": 2000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (op) (proxy_request_duration_ms{quantile=\"0.95\",target=~\"$target\",op=~\"$op\"})",
          "legendFormat": "{{op}}",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "type": "heatmap",
      "title": "p99 — heatmap por operação",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 25 },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "ms" },
        "color": { "mode": "scheme", "scheme": "Spectral", "steps": 64, "reverse": true },
        "tooltip": { "show": true, "yHistogram": false },
        "legend": { "show": true }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (op) (proxy_request_duration_ms{quantile=\"0.99\",target=~\"$target\",op=~\"$op\"})",
          "legendFormat": "{{op}}",
          "format": "time_series"
        }
      ]
    },

    {
      "type": "row",
      "id": 400,
      "title": "Status HTTP & códigos de erro upstream",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Requests por status HTTP (rps)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 35 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 0, "stacking": { "mode": "normal", "group": "status" } }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "^2.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byRegexp", "options": "^3.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byRegexp", "options": "^4.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byRegexp", "options": "^5.." }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(proxy_requests_status_total{target=~\"$target\",op=~\"$op\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "piechart",
      "title": "Distribuição de status (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 35 },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "desc" }
      },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (increase(proxy_requests_status_total{target=~\"$target\",op=~\"$op\"}[$__range]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Códigos de erro upstream (PGRST002, 57014, …)",
      "description": "Total de cada err_code reportado pelo proxy no range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 44 },
      "options": { "showHeader": true },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Total" }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 50 }] } }] }
        ]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true }, "indexByName": { "code": 0, "op": 1, "target": 2, "Value": 3 } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] } }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (code, op, target) (increase(proxy_error_codes_total{target=~\"$target\",op=~\"$op\"}[$__range]))",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Erros por código upstream (rps)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 44 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (code) (rate(proxy_error_codes_total{target=~\"$target\",op=~\"$op\"}[5m]))",
          "legendFormat": "{{code}}"
        }
      ]
    },

    {
      "type": "row",
      "id": 500,
      "title": "Top operações com mais erro",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "panels": []
    },
    {
      "id": 14,
      "type": "table",
      "title": "Operações ranqueadas por erro % (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 55 },
      "options": { "showHeader": true },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error_pct" }, "properties": [{ "id": "displayName", "value": "Erro %" }, { "id": "unit", "value": "percent" }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "orange", "value": 5 }, { "color": "red", "value": 10 }] } }] },
          { "matcher": { "id": "byName", "options": "p95_ms" }, "properties": [{ "id": "displayName", "value": "p95 (ms)" }, { "id": "unit", "value": "ms" }] },
          { "matcher": { "id": "byName", "options": "rps" }, "properties": [{ "id": "displayName", "value": "rps" }, { "id": "unit", "value": "reqps" }] }
        ]
      },
      "transformations": [
        { "id": "merge" },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "indexByName": { "op": 0, "target": 1, "rps": 2, "error_pct": 3, "p95_ms": 4 } } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "error_pct", "desc": true }] } }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (op, target) (increase(proxy_requests_error_total{target=~\"$target\",op=~\"$op\"}[$__range])) / clamp_min(sum by (op, target) (increase(proxy_requests_total{target=~\"$target\",op=~\"$op\"}[$__range])), 1)",
          "instant": true,
          "format": "table",
          "legendFormat": "error_pct"
        },
        {
          "refId": "B",
          "expr": "sum by (op, target) (rate(proxy_requests_total{target=~\"$target\",op=~\"$op\"}[5m]))",
          "instant": true,
          "format": "table",
          "legendFormat": "rps"
        },
        {
          "refId": "C",
          "expr": "max by (op, target) (proxy_request_duration_ms{quantile=\"0.95\",target=~\"$target\",op=~\"$op\"})",
          "instant": true,
          "format": "table",
          "legendFormat": "p95_ms"
        }
      ]
    }
  ]
}
