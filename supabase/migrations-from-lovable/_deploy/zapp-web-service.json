{
  "Name": "zapp-web_web",
  "Labels": {
    "com.docker.stack.image": "nginx:alpine",
    "com.docker.stack.namespace": "zapp-web",
    "traefik.enable": "true",
    "traefik.http.routers.zappweb.entrypoints": "websecure",
    "traefik.http.routers.zappweb.rule": "Host(`zapp.atomicabr.com.br`)",
    "traefik.http.routers.zappweb.service": "zappweb",
    "traefik.http.routers.zappweb.tls.certresolver": "letsencryptresolver",
    "traefik.http.services.zappweb.loadbalancer.server.port": "80"
  },
  "TaskTemplate": {
    "ContainerSpec": {
      "Image": "nginx:alpine",
      "Args": [
        "sh", "-c",
        "apk add --no-cache curl > /dev/null 2>&1; rm -f /etc/nginx/conf.d/default.conf && cp /workspace/zapp-web-nginx/nginx.conf /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"
      ],
      "Mounts": [
        {
          "Source": "claude-code_workspace",
          "Target": "/workspace",
          "Type": "volume",
          "ReadOnly": true
        }
      ],
      "Healthcheck": {
        "Test": ["CMD", "curl", "-sf", "http://localhost/healthz"],
        "Interval": 30000000000,
        "Timeout": 5000000000,
        "Retries": 3,
        "StartPeriod": 15000000000
      },
      "Labels": {
        "com.docker.stack.namespace": "zapp-web"
      }
    },
    "Networks": [
      { "Target": "40h0f38co6ow3kq3v80u0d5ke", "Aliases": ["web"] }
    ],
    "Placement": {
      "Constraints": ["node.role == manager"]
    },
    "Resources": {
      "Limits": {
        "MemoryBytes": 134217728,
        "NanoCPUs": 500000000
      }
    }
  },
  "Mode": {
    "Replicated": { "Replicas": 1 }
  },
  "EndpointSpec": {
    "Mode": "vip"
  }
}
